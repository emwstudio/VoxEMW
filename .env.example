# ---- LiveKit Cloud 凭证（必填，https://cloud.livekit.io 项目 Settings -> Keys）----
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret

# ---- LLM（本机 vLLM OpenAI 兼容服务）----
LLM_BASE_URL=http://127.0.0.1:8000/v1
LLM_MODEL=Qwen/Qwen3-8B-AWQ
LLM_API_KEY=EMPTY

# ---- 良子音色克隆素材 ----
# 10-30s 清晰单人声 wav
LIANGZI_REF_WAV=assets/liangzi/ref.wav
# 上面这段音频的逐字台词 txt 文件路径（Ultimate Cloning 需要）
LIANGZI_REF_TEXT=assets/liangzi/ref.txt

# ---- Hugging Face token（下载受限模型时需要）----
HF_TOKEN=

# ---- 可选: STT/TTS 设备与模型覆盖 ----
STT_MODEL=Qwen/Qwen3-ASR-1.7B-hf
# STT_LANGUAGE=Chinese
# STT_DEVICE=cuda
# TTS_MODEL=openbmb/VoxCPM2
# TTS_DEVICE=cuda

# ---- 可选: vLLM 显存配比（24GB 三模型共用，默认 0.35）----
# VLLM_GPU_MEM_UTIL=0.35
# VLLM_MAX_MODEL_LEN=4096
